# Optional local LLM support
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-council

# Optional handwriting VLM support on Apple Silicon
HANDWRITING_TRANSCRIPTION_BACKEND=auto
HANDWRITING_VLM_MODEL=mlx-community/Qwen2.5-VL-3B-Instruct-4bit
HANDWRITING_VLM_TIMEOUT=180

# Optional command override for custom local VLM runner
# HANDWRITING_VLM_COMMAND=python -m mlx_vlm.generate --model {model} --image {image} --prompt {prompt}

