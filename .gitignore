# macOS / editor noise
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
backend/venv/
backend/.venv/

# Node / frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Flutter/mobile build output
mobile/.dart_tool/
mobile/build/
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/ios/Flutter/ephemeral/
mobile/android/.gradle/
mobile/android/local.properties

# Runtime data: never commit real uploads, processed outputs, or local DBs
backend/data/*.db
backend/data/*.sqlite3
backend/data/uploads/*
backend/data/processed/*
!backend/data/uploads/.gitkeep
!backend/data/processed/.gitkeep

# Keep synthetic demo docs only
backend/data/demo_docs/*
!backend/data/demo_docs/.gitkeep
!backend/data/demo_docs/*.png

# Local models and caches
models/
.cache/
*.safetensors
*.gguf
*.onnx

# Generated reports that may contain OCR/private text
backend/data/**/report.json
backend/data/**/handwriting_report.json

# Environment / secrets
.env
.env.*
!.env.example

