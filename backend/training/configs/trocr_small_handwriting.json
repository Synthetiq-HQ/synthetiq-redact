{
  "base_model": "microsoft/trocr-small-handwritten",
  "output_dir": "backend/training/models/trocr-small-council-handwriting",
  "max_target_length": 128,
  "image_size": 384,
  "train_batch_size": 2,
  "eval_batch_size": 2,
  "gradient_accumulation_steps": 8,
  "learning_rate": 0.00005,
  "weight_decay": 0.01,
  "num_train_epochs": 6,
  "warmup_ratio": 0.05,
  "fp16": true,
  "gradient_checkpointing": true,
  "early_stopping_patience": 3,
  "save_total_limit": 3,
  "eval_steps": 250,
  "save_steps": 250,
  "logging_steps": 25,
  "seed": 42
}
